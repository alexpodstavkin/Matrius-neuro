# Скопируйте этот файл в `.env` и заполните значения.
# Файл `.env` НЕ коммитится в репозиторий.

# Поддомен в URL аккаунта GC (`matrius.getcourse.ru` → `matrius`)
# или полный кастомный домен (например, `school-genius.club`).
GC_ACCOUNT=

# Секретный ключ из админки GC: Настройки → Общее → API.
GC_SECRET_KEY=

# Код оффера (числовой ID или текстовый alias).
GC_OFFER_CODE=8331347

# Список разрешённых origin'ов через запятую (для CORS, если фронт на другом домене).
# Если фронт и backend на одном origin — не критично, можно оставить дефолт.
ALLOWED_ORIGINS=https://web.matrius.online
