# GetCourse API — заполните своими значениями и переименуйте в .env.local
# Поддомен вашего GetCourse-аккаунта (без https и слешей), например: matrius
GETCOURSE_ACCOUNT=matrius
# API-ключ из настроек GetCourse → Пользователи → Управление пользователями
GETCOURSE_API_KEY=
# ID группы, в которую добавлять лидов (например, «Лето-Скорочтение-2026»)
GETCOURSE_GROUP_ID=
